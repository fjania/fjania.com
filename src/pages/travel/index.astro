---
import Base from '../../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { parseFlights, safeJsonForScript } from '../../lib/parseFlights';
import '../../styles/travel.css';

const csvPath = path.resolve('./src/data/flights.csv');
const csvText = fs.readFileSync(csvPath, 'utf-8');
const flights = parseFlights(csvText);

const worldPath = path.resolve('./src/data/world-110m.json');
const worldText = fs.readFileSync(worldPath, 'utf-8');

const flightsJson = safeJsonForScript(flights);

const issueDate = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<Base title="Travel — Frank Jania">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=JetBrains+Mono:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <article class="travel-page">
    <div class="dateline" aria-hidden="true">
      <span>Vol. I &nbsp;·&nbsp; No. 01</span>
      <span class="dateline-mid">— An Atlas of Flight —</span>
      <span>{issueDate}</span>
    </div>

    <header class="masthead">
      <div class="masthead-left">
        <p class="eyebrow">A personal cartography, est. <span class="num">2009</span></p>
        <h1 class="masthead-title">
          <span class="display-italic">Travel</span>
        </h1>
      </div>
      <div class="masthead-right">
        <p class="lede">
          Every flight Frank Jania has ever taken, recovered from fifteen years of email and plotted as great-circle arcs across a flat earth. <span class="lede-figure">{flights.length} segments</span>, <span class="lede-figure">32 countries</span>, more than five hundred thousand miles.
        </p>
      </div>
    </header>

    <div class="rule rule-double" role="presentation"></div>

    <section class="control-deck" aria-label="Filters and live stats">
      <div id="filters" class="filters" aria-label="Filters"></div>
      <button id="reset-filters" class="reset-link" type="button" aria-label="Clear all filters">Clear all</button>
      <div id="stats" class="stats-banner" aria-live="polite"></div>
    </section>

    <section class="atlas" aria-label="World map and trip log">
      <div class="atlas-main">
        <p class="figure-label"><span>Fig. I</span> — The world, after fifteen years <span class="figure-hint">— hover an arc, click an airport, drag the timeline</span></p>
        <div class="map-stage">
          <svg id="map-svg" viewBox="0 0 960 500" role="img" aria-label="World map with great-circle arcs of all flights"></svg>
          <div class="compass" aria-hidden="true">
            <span class="compass-n">N</span>
            <span class="compass-arrow">↑</span>
          </div>
        </div>
        <div class="timeline-strip" aria-label="Monthly timeline (brushable filter)">
          <svg id="timeline-svg" role="group" aria-label="Drag the handles to filter by month range"></svg>
        </div>
      </div>

      <aside class="trips-panel" aria-label="Trips">
        <div class="trips-header">
          <h2><span class="display-italic">Trips</span></h2>
          <span id="trips-count" class="trips-count"></span>
        </div>
        <div id="trips"></div>
      </aside>
    </section>

    <div class="ornament" aria-hidden="true">❦</div>

    <section class="leaderboards-figure" aria-label="Top routes, airports, and yearly totals">
      <div class="leaderboards">
        <div class="lb-card">
          <p class="lb-title">Routes, most flown</p>
          <div id="lb-routes"></div>
        </div>
        <div class="lb-card">
          <p class="lb-title">Airports, most visited</p>
          <div id="lb-airports"></div>
        </div>
        <div class="lb-card">
          <p class="lb-title">Segments by year <span class="lb-hint">— click to filter</span></p>
          <div id="lb-annual"></div>
        </div>
      </div>
    </section>

    <footer class="colophon">
      <div class="rule rule-double" role="presentation"></div>
      <p>
        Set in <em>Fraunces</em> and <em>JetBrains Mono</em>. Data sourced from a decade and a half of email. Map projection: Natural Earth. Plotted with <em>d3-geo</em> against <em>world-atlas</em>.
      </p>
    </footer>
  </article>

  <script type="application/json" id="travel-flights" set:html={flightsJson}></script>
  <script type="application/json" id="travel-world" set:html={worldText}></script>
  <script>
    import '../../scripts/travel/bootstrap.js';
  </script>
</Base>
