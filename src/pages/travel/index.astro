---
import Base from '../../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { parseFlights, safeJsonForScript } from '../../lib/parseFlights';
import '../../styles/travel.css';

const csvPath = path.resolve('./src/data/flights.csv');
const csvText = fs.readFileSync(csvPath, 'utf-8');
const flights = parseFlights(csvText);

const worldPath = path.resolve('./src/data/world-110m.json');
const worldText = fs.readFileSync(worldPath, 'utf-8');

const flightsJson = safeJsonForScript(flights);
---

<Base title="Travel — Frank Jania">
  <div class="travel-page">
    <header class="travel-header">
      <h1>Travel</h1>
      <p class="subtitle">{flights.length} segments flown since 2009</p>
    </header>

    <section id="stats" class="stats-strip" aria-label="Summary statistics"></section>

    <section class="filters-section" aria-label="Filters">
      <label>From year
        <input type="number" id="year-min" min="2009" max="2026" value="2009" step="1" />
      </label>
      <label>to
        <input type="number" id="year-max" min="2009" max="2026" value="2026" step="1" />
      </label>
    </section>

    <section class="map-section" aria-label="Map of flights">
      <svg id="map-svg" viewBox="0 0 960 500" role="img" aria-label="World map with great-circle arcs of all flights"></svg>
    </section>

    <section class="leaderboards" aria-label="Top routes and airports">
      <div class="lb-card">
        <h2>Most-flown routes</h2>
        <div id="lb-routes"></div>
      </div>
      <div class="lb-card">
        <h2>Most-visited airports</h2>
        <div id="lb-airports"></div>
      </div>
    </section>
  </div>

  <script type="application/json" id="travel-flights" set:html={flightsJson}></script>
  <script type="application/json" id="travel-world" set:html={worldText}></script>
  <script>
    import '../../scripts/travel/bootstrap.js';
  </script>
</Base>
