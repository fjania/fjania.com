---
import Base from '../../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { parseFlights } from '../../lib/parseFlights';

const csvPath = path.resolve('./src/data/flights.csv');
const csvText = fs.readFileSync(csvPath, 'utf-8');
const flights = parseFlights(csvText);
const first = flights[0];
---

<Base title="Travel — Frank Jania">
  <main style="max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem;">
    <h1>Travel (scaffold)</h1>
    <p>Parsed {flights.length} flights from <code>src/data/flights.csv</code>.</p>
    <h2>First flight</h2>
    <pre style="background: #f5f5f0; padding: 1rem; border-radius: 8px; overflow-x: auto;">{JSON.stringify(first, null, 2)}</pre>
  </main>
</Base>
