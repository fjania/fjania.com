---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import '../../../styles/manuals.css';

export async function getStaticPaths() {
  const manuals = await getCollection('manuals');
  return manuals.map(manual => ({
    params: { slug: manual.id },
    props: { manual: manual.data },
  }));
}

const { manual } = Astro.props;
const { slug } = Astro.params;

function categoryLabel(cat: string): string {
  return cat.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const contentModules = import.meta.glob('./content/*.astro', { eager: true });
const contentKey = `./content/${slug}.astro`;
const ContentComponent = contentModules[contentKey]?.default;
---

<Base title={`${manual.name} — Owner's Manual`}>
  <div class="manual-detail">
    <div class="manual-header">
      <div class="category">{categoryLabel(manual.category)}</div>
      <h1>{manual.name}</h1>
      <p class="manufacturer">{manual.manufacturer} &middot; Model {manual.model}</p>
      <div class="actions">
        <a href={`/manuals/${manual.pdf}`} class="pdf-link" download>Download PDF ({manual.pages} pages)</a>
        <a href="/workshop/manuals/" class="back-link">All Manuals</a>
      </div>
    </div>

    <div class="manual-content">
      {ContentComponent ? <ContentComponent /> : <p>Manual content not yet available. <a href={`/manuals/${manual.pdf}`} download>Download the PDF</a> to view the full manual.</p>}
    </div>
  </div>
</Base>
