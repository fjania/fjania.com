<style>
  .pegas-sheet {
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .pegas-sheet h2.chart-title {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: #2c2c2c;
    margin-bottom: 1.5rem;
    border: none;
    padding: 0;
  }

  /* Legend */
  .legend {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 0.4rem 2rem;
    align-items: start;
    margin-bottom: 1.5rem;
    padding: 0.6rem 1rem;
    background: #f8f8f5;
    border: 1px solid #e0ddd5;
    border-radius: 6px;
    font-size: 0.78rem;
  }
  .legend-group h4 { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.5px; color: #888; margin-bottom: 0.25rem; }
  .legend-item { display: inline-flex; align-items: center; gap: 0.35rem; margin-right: 1rem; }
  .legend-mat { display: flex; flex-wrap: wrap; }
  .legend-finish { display: flex; flex-wrap: wrap; gap: 0.15rem 1rem; }

  /* Finish quality bars */
  .finish-bar {
    display: inline-flex;
    gap: 2px;
    vertical-align: middle;
  }
  .finish-bar .bar-seg {
    width: 5px;
    height: 12px;
    background: #d4d0c8;
    border-radius: 1px;
  }
  .finish-bar .bar-seg.filled { background: #4a9e4a; }
  .finish-bar-na {
    color: #aaa;
    font-size: 0.75rem;
  }

  /* Abbreviations */
  .abbrev-all {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 0.1rem 1.2rem;
    font-size: 0.75rem;
    line-height: 1.6;
  }
  .abbrev-all span { white-space: nowrap; }
  .abbrev-all strong { color: #555; margin-right: 0.3rem; }
  @media (max-width: 700px) {
    .abbrev-all { grid-template-columns: repeat(2, auto); }
  }

  @media (max-width: 800px) {
    .legend { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 500px) {
    .legend { grid-template-columns: 1fr; }
  }

  /* Material suitability icons */
  .mat-e, .mat-g, .mat-n {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .mat-e { background: #4a9e4a; }
  .mat-g { background: #d4a843; }
  .mat-n { background: #d4d0c8; }

  /* Blade type section */
  .blade-section {
    margin-bottom: 2rem;
  }
  .blade-section h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #2c2c2c;
    margin-bottom: 0.2rem;
    border: none;
    padding: 0;
  }
  .blade-section h3 span {
    font-weight: 400;
    font-size: 0.85rem;
    color: #888;
  }
  .blade-section .section-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.3rem;
  }
  .blade-section .section-title-row .blade-profile {
    flex-shrink: 0;
    width: 450px;
    height: auto;
    object-fit: contain;
  }
  @media (max-width: 700px) {
    .blade-section .section-title-row { flex-direction: column; align-items: flex-start; }
    .blade-section .section-title-row .blade-profile { width: 100%; max-width: 300px; }
  }
  .blade-section .type-desc {
    font-size: 0.78rem;
    color: #555;
    margin-bottom: 0;
    line-height: 1.5;
  }

  /* Blade table */
  .blade-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
    margin-bottom: 0.5rem;
  }
  .blade-table th,
  .blade-table td {
    border: 1px solid #d4d0c8;
    padding: 0.25rem 0.4rem;
    text-align: center;
    vertical-align: middle;
    white-space: nowrap;
  }
  .blade-table thead th {
    background: #f0ede6;
    font-weight: 600;
    color: #555;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .blade-table tbody tr:nth-child(even) {
    background: #fafaf7;
  }
  .blade-table td.model-cell {
    font-weight: 600;
    text-align: left;
    color: #2c2c2c;
  }
  .blade-table td.mat-cell {
    padding: 0.2rem 0.15rem;
  }
  .blade-table td.opt-cell {
    white-space: nowrap;
    text-align: center;
  }
  .blade-table td.check {
    color: #4a9e4a;
    font-weight: 700;
  }

  /* Tips section */
  .tips-section {
    margin-top: 2rem;
    padding: 1rem;
    background: #f8f8f5;
    border: 1px solid #e0ddd5;
    border-radius: 6px;
  }
  .tips-section h3 {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
  }
  .tips-section ul {
    margin: 0.5rem 0;
    padding-left: 1.2rem;
    font-size: 0.82rem;
  }
  .tips-section li { margin-bottom: 0.2rem; }

  .wood-class {
    margin-top: 1rem;
    padding: 0.8rem;
    background: #f0ede6;
    border-radius: 4px;
    font-size: 0.78rem;
    line-height: 1.6;
  }
  .wood-class strong { color: #2c2c2c; }

  /* Fractions */
  .frac {
    font-feature-settings: normal;
    white-space: nowrap;
  }
  .frac sup, .frac sub {
    font-size: 0.7em;
    vertical-align: baseline;
    position: relative;
  }
  .frac sup { top: -0.35em; }
  .frac sub { bottom: -0.15em; }

  /* Responsive */
  @media (max-width: 900px) {
    .blade-table {
      font-size: 0.68rem;
    }
    .blade-table th,
    .blade-table td {
      padding: 0.2rem 0.25rem;
    }
    .mat-e, .mat-g, .mat-n {
      width: 10px;
      height: 10px;
    }
  }
  .blade-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
</style>

<div class="pegas-sheet">
  <h2 class="chart-title">Selection Chart &amp; Technical Data</h2>

  <div class="legend">
    <div class="legend-group">
      <h4>Material Suitability</h4>
      <div class="legend-mat">
        <div class="legend-item"><span class="mat-e"></span> Excellent</div>
        <div class="legend-item"><span class="mat-g"></span> OK</div>
        <div class="legend-item"><span class="mat-n"></span> Not rec.</div>
      </div>
    </div>
    <div class="legend-group">
      <h4>Finish Quality</h4>
      <div class="legend-finish">
        <div class="legend-item"><span class="finish-bar"><span class="bar-seg filled"></span><span class="bar-seg"></span><span class="bar-seg"></span><span class="bar-seg"></span></span> Medium</div>
        <div class="legend-item"><span class="finish-bar"><span class="bar-seg filled"></span><span class="bar-seg filled"></span><span class="bar-seg"></span><span class="bar-seg"></span></span> Good</div>
        <div class="legend-item"><span class="finish-bar"><span class="bar-seg filled"></span><span class="bar-seg filled"></span><span class="bar-seg filled"></span><span class="bar-seg"></span></span> Excellent</div>
        <div class="legend-item"><span class="finish-bar"><span class="bar-seg filled"></span><span class="bar-seg filled"></span><span class="bar-seg filled"></span><span class="bar-seg filled"></span></span> Incredibly fine</div>
      </div>
    </div>
    <div class="legend-group">
      <h4>Abbreviations</h4>
      <div class="abbrev-all">
        <span><strong>AL</strong>Alu, Brass, Copper</span>
        <span><strong>CO</strong>Corian / Plastics</span>
        <span><strong>FE</strong>Ferrous Metals</span>
        <span><strong>HW</strong>Hardwoods</span>
        <span><strong>Int.</strong>Intricate cuts</span>
        <span><strong>MH</strong>Med. Hardwoods</span>
        <span><strong>PW</strong>Plywood</span>
        <span><strong>Surf.</strong>Surface finish</span>
        <span><strong>SW</strong>Softwoods</span>
        <span><strong>TPI</strong>Teeth/inch</span>
        <span><strong>Under.</strong>Underside finish</span>
      </div>
    </div>
  </div>

  {sections.map((section) => (
    <div class="blade-section">
      <div class="section-title-row">
        <h3>{section.name} <span>({section.len})</span></h3>
        {section.img && <img class="blade-profile" src={`/spec-sheets/${section.img}`} alt={`${section.name} tooth profile`} />}
      </div>
      <p class="type-desc">{section.desc}</p>

      <div class="blade-table-wrap">
        <table class="blade-table">
          <thead>
            <tr>
              <th>Model</th>
              <th>Univ.&nbsp;#</th>
              <th>Thick</th>
              {!section.spiral && <th>Width</th>}
              <th>TPI</th>
              <th>Trace</th>
              {matLabels.map(l => <th title={matNames[matLabels.indexOf(l)]}>{l}</th>)}
              <th>Optimal Thickness</th>
              <th title="Intricate cuts">Int.</th>
              <th title="Tight turns">Tight</th>
              <th title="Surface finish">Surf.</th>
              <th title="Underside finish">Under.</th>
              {section.pinned
                ? <th>Pin</th>
                : <><th>Drill</th><th>Hole</th></>
              }
            </tr>
          </thead>
          <tbody>
            {section.blades.map((b) => (
              <tr>
                <td class="model-cell">{b[0]}</td>
                <td>{b[1]}</td>
                <td>{b[2]}</td>
                {!section.spiral && <td>{b[3]}</td>}
                <td>{b[4]}</td>
                <td>{b[5]}</td>
                {b[6].split('').map((c: string) => (
                  <td class="mat-cell"><span class={matClass(c)}></span></td>
                ))}
                <td class="opt-cell" set:html={frac(b[7])} />
                <td class="check">{b[8]}</td>
                <td class="check">{b[9]}</td>
                <td>{finishBars(b[10]) > 0
                  ? <span class="finish-bar">{[1,2,3,4].map(i => <span class={`bar-seg${i <= finishBars(b[10]) ? ' filled' : ''}`}></span>)}</span>
                  : <span class="finish-bar-na">&ndash;</span>
                }</td>
                <td>{finishBars(b[11]) > 0
                  ? <span class="finish-bar">{[1,2,3,4].map(i => <span class={`bar-seg${i <= finishBars(b[11]) ? ' filled' : ''}`}></span>)}</span>
                  : <span class="finish-bar-na">&ndash;</span>
                }</td>
                {section.pinned
                  ? <td set:html={frac(b[13])} />
                  : <><td>{b[12]}</td><td>{b[13]}</td></>
                }
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}

  <div class="tips-section">
    <h3>General Tips for Selecting Blades</h3>
    <p>The smaller the blade number is, the smaller radius it will cut.<br>
    The smaller the blade number is, the narrower the TRACE will be.</p>
    <p>Before starting a new project, ask yourself these questions:</p>
    <ul>
      <li>What type of wood am I cutting?</li>
      <li>How thick is the piece of wood?</li>
      <li>How thin does the cut line need to be (Puzzle, Intarsia)?</li>
      <li>What finish do it need?</li>
    </ul>

    <div class="wood-class">
      <strong>HARDWOODS:</strong> Beech, Bloodwood, Bocote, Bubinga, Canarywood, Cocobolo, Ebony, Elm, Hickory, Hornbeam, Jatoba, Leopardwood, Lyptus, Marblewood, Mora, Oleaster, Purpleheart, Rosewood, Wenge, Yellowheart, Zebrawood.<br>
      <strong>MEDIUM HARDWOODS:</strong> Ash, Black Cherry, Cherry, Eucalyptus, Limba, Macacauba, Mahogany, Maple, Nogal, Oak, Padauk, Redheart, Sapele, Teak, Tzalam, Walnut.<br>
      <strong>SOFTWOODS:</strong> Alder, Balsa, Basswood, Birch, Black Willow, Chestnut, Cedar, Cypress, Fir, Larch, Pine, Poplar, Redwood, Spanish Cedar, Spruce.
    </div>
  </div>
</div>
