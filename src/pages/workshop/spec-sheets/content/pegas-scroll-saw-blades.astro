// Reorder: MGT first, Spiral second, then the rest in original order
const mgt = allSections.find(s => s.name === "Modified Geometry");
const spiral = allSections.find(s => s.name === "Spiral");
const rest = allSections.filter(s => s.name !== "Modified Geometry" && s.name !== "Spiral");
const sections = [mgt, spiral, ...rest];

const matLabels = ["HW","MH","SW","PW","CO","AL","FE"];
const matNames = ["Hardwoods","Medium Hardwoods","Softwoods","Plywood","Corian / Plastics","Alu, Brass, Copper","Ferrous Metals"];

function matClass(c: string) {
  if (c === 'E') return 'mat-e';
  if (c === 'G') return 'mat-g';
  return 'mat-n';
}

function frac(str: string): string {
  // Strip first " before dash, normalize dash to en-dash with thin spaces
  let s = str.replace(/"\s*-\s*/g, ' \u2013 ');
  s = s.replace(/\s+-\s+/g, ' \u2013 ');
  s = s.replace(/(\d)-/g, '$1 \u2013 ');
  // Convert fractions to styled HTML
  s = s.replace(/(\d+)\/(\d+)/g, '<span class="frac"><sup>$1</sup>&frasl;<sub>$2</sub></span>');
  return s;
}

function finishBars(val: string): number {
  if (val === '++++') return 4;
  if (val === '+++') return 3;
  if (val === '++') return 2;
  if (val === '+') return 1;
  return 0; // "-" or empty
}
