---
const title = "Frank Jania";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      line-height: 1.6;
      color: #2c2c2c;
      background: #fafafa;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 6rem 1.5rem;
    }
    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }
    .lead {
      font-size: 1.15rem;
      color: #444;
      margin-bottom: 0.75rem;
    }
    .links {
      margin-top: 1.5rem;
      font-size: 0.95rem;
      color: #666;
    }
    a {
      color: #2563eb;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Hi, I'm Frank</h1>
    <p class="lead">I am driven to create technology that helps people understand and make sense of the world around us.</p>
    <p class="lead">Have a look at my <a href="/resume/">resume</a>.</p>
    <p class="links">Threads: <a href="https://www.threads.net/@fjania">@fjania</a></p>
  </div>
</body>
</html>
