---
import { getCollection } from 'astro:content';

const all = await getCollection('resume');
const jobs = all
  .filter(e => e.data.section === 'jobs')
  .sort((a, b) => b.id.localeCompare(a.id));
const education = all
  .filter(e => e.data.section === 'education')
  .sort((a, b) => b.id.localeCompare(a.id));
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resume — Frank Jania</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      line-height: 1.6;
      color: #2c2c2c;
      background: #fafafa;
    }
    .container {
      max-width: 740px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }
    a { color: #2563eb; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .back { font-size: 0.9rem; margin-bottom: 2rem; display: inline-block; }
    section { margin-bottom: 2.5rem; }
    section > h2 {
      font-size: 1.3rem;
      font-weight: 700;
      border-bottom: 2px solid #e5e5e5;
      padding-bottom: 0.4rem;
      margin-bottom: 1.5rem;
    }
    .statement {
      font-size: 1.05rem;
      color: #444;
      line-height: 1.7;
    }
    article { margin-bottom: 2rem; }
    .job-title, .edu-degree {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.15rem;
    }
    .job-meta, .edu-meta {
      font-size: 0.9rem;
      color: #666;
      margin-bottom: 0.5rem;
    }
    .dates {
      float: right;
      font-style: italic;
    }
    .summary {
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
    }
    ul.bullets {
      list-style: none;
      padding: 0;
    }
    ul.bullets li {
      padding: 0.2rem 0 0.2rem 1rem;
      position: relative;
      font-size: 0.9rem;
      color: #444;
      line-height: 1.5;
    }
    ul.bullets li::before {
      content: "\2022";
      position: absolute;
      left: 0;
      color: #ccc;
    }
    .thesis {
      font-size: 0.9rem;
      color: #444;
      margin-bottom: 0.4rem;
    }
    .edu-description {
      font-size: 0.9rem;
      color: #555;
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="back">&larr; fjania.com</a>

    <section>
      <h2>Personal Statement</h2>
      <p class="statement">I find my greatest professional joy when I am building new technologies that help people make sense of the world and express themselves. The subject areas I am most fond of are collaboration, messaging, social tools, data visualization, music, and fitness. I am a compassionate manager and leader, a sincere teammate who thrives in an environment of smart and creative people that regularly challenge each other, and a prolific inventor.</p>
    </section>

    <section>
      <h2>Work Experience</h2>
      {jobs.map(job => (
        <article>
          <div class="job-title">{job.data.title}</div>
          <div class="job-meta">
            {job.data.company}
            <span class="dates">{job.data.dates}</span>
          </div>
          {job.data.summary && <p class="summary">{job.data.summary}</p>}
          {job.data.bullets && job.data.bullets.length > 0 && (
            <ul class="bullets">
              {job.data.bullets.map(b => <li>{b}</li>)}
            </ul>
          )}
        </article>
      ))}
    </section>

    <section>
      <h2>Education</h2>
      {education.map(edu => (
        <article>
          <div class="edu-degree">{edu.data.title}</div>
          <div class="edu-meta">
            {edu.data.school}
            <span class="dates">{edu.data.dates}</span>
          </div>
          {edu.data.thesis && <p class="thesis"><strong>Thesis:</strong> {edu.data.thesis}</p>}
          {edu.data.description && <p class="edu-description">{edu.data.description}</p>}
        </article>
      ))}
    </section>
  </div>
</body>
</html>
