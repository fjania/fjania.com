---
interface Props {
  species: {
    name: string;
    also_known_as?: string[];
    scientific: string;
    origin: string;
    appearance: {
      heartwood: string;
      sapwood: string;
      grain: string;
      texture: string;
      luster: string;
    };
    properties: {
      janka: number;
      density: string;
      workability: string;
      turning: string;
      gluing: string;
      finishing: string;
    };
    uses: string[];
    advantages: string[];
    challenges: string[];
    finishing_tips: string[];
    buying_tips: string[];
    fun_fact: string;
    comparisons: { title: string; rows: Record<string, string>[] }[];
    faqs: { q: string; a: string }[];
  };
  maxJanka: number;
  images: string[];
}

const { species: sp, maxJanka, images } = Astro.props;
const jankaPct = Math.min(100, (sp.properties.janka / maxJanka) * 100);
const slug = sp.name.toLowerCase().replace(/ /g, '_');
const captions = ['Product Example 1', 'Product Example 2', 'Product Example 3'];
---

<!-- Front page -->
<div class="page front">
  <header class="banner">
    <div class="banner-text">
      <h1>{sp.name}</h1>
      <div class="subtitle">{sp.scientific} &mdash; {sp.origin}</div>
      {sp.also_known_as && sp.also_known_as.length > 0 && (
        <div class="aka">Also known as: {sp.also_known_as.join(', ')}</div>
      )}
    </div>
    {images.length > 0 && (
      <div class="banner-thumbs">
        {images.slice(0, 3).map(img => (
          <img src={`/workshop/species-images/${img}`} alt={sp.name}>
        ))}
      </div>
    )}
  </header>

  <div class="stats-strip">
    <div class="stat"><div class="label">Janka Hardness</div><div class="value">{sp.properties.janka.toLocaleString()} lbf</div></div>
    <div class="stat"><div class="label">Density</div><div class="value">{sp.properties.density}</div></div>
    <div class="stat"><div class="label">Origin</div><div class="value">{sp.origin}</div></div>
    <div class="stat"><div class="label">Grain</div><div class="value">{sp.appearance.grain}</div></div>
  </div>

  <div class="two-col">
    <div class="group">
      <div class="group-header">About This Wood</div>

      <div class="section-title">Appearance</div>
      <div class="section-text">
        <strong>Heartwood:</strong> {sp.appearance.heartwood}<br>
        <strong>Sapwood:</strong> {sp.appearance.sapwood}<br>
        <strong>Texture:</strong> {sp.appearance.texture}<br>
        <strong>Lustre:</strong> {sp.appearance.luster}
      </div>

      <div class="section-title">Why Choose It</div>
      <ul class="adv-list">
        {sp.advantages.map(item => <li>{item}</li>)}
      </ul>

      <div class="section-title">Common Uses</div>
      <ul class="uses-list">
        {sp.uses.map(item => <li>{item}</li>)}
      </ul>
    </div>

    <div class="group">
      <div class="group-header">Workshop Guide</div>

      <div class="section-title">Working Properties</div>
      <div class="section-text">
        <strong>Workability:</strong> {sp.properties.workability}<br>
        <strong>Turning:</strong> {sp.properties.turning}<br>
        <strong>Gluing:</strong> {sp.properties.gluing}<br>
        <strong>Finishing:</strong> {sp.properties.finishing}
      </div>

      <div class="section-title">Watch Out For</div>
      <ul class="chal-list">
        {sp.challenges.map(item => <li>{item}</li>)}
      </ul>

      <div class="section-title">Finishing Tips</div>
      <ul class="tips-list">
        {sp.finishing_tips.map(item => <li>{item}</li>)}
      </ul>

      <div class="section-title">Buying Tips</div>
      <ul class="buying-list">
        {sp.buying_tips.map(item => <li>{item}</li>)}
      </ul>
    </div>
  </div>

  <div class="janka-strip">
    <div class="janka-label">Janka Hardness &mdash; {sp.properties.janka.toLocaleString()} lbf</div>
    <div class="janka-bar-container">
      <div class="janka-bar-fill" style={`width: ${jankaPct.toFixed(1)}%`}>
        <span class="janka-bar-label">{sp.properties.janka.toLocaleString()}</span>
      </div>
    </div>
  </div>

  <div class="comparisons">
    {sp.comparisons.slice(0, 2).map(comp => (
      <div>
        <div class="comp-label">{comp.title}</div>
        <table class="comp-table">
          <tr>
            {Object.keys(comp.rows[0]).map(h => <th>{h}</th>)}
          </tr>
          {comp.rows.map(row => (
            <tr>
              {Object.values(row).map(v => <td>{v}</td>)}
            </tr>
          ))}
        </table>
      </div>
    ))}
  </div>

  <footer class="fun-fact">
    <strong>Did you know?</strong> {sp.fun_fact}
  </footer>
</div>

<!-- Back page -->
<div class="page back">
  <header class="banner">
    <div class="banner-text">
      <h1>{sp.name}</h1>
      <div class="subtitle">Visual Reference & FAQ</div>
    </div>
    {images.length > 0 && (
      <div class="banner-thumbs">
        {images.slice(0, 3).map(img => (
          <img src={`/workshop/species-images/${img}`} alt={sp.name}>
        ))}
      </div>
    )}
  </header>

  <div class="colour-ref">
    <div class="colour-item"><div class="colour-label">Heartwood</div><div class="colour-value">{sp.appearance.heartwood}</div></div>
    <div class="colour-item"><div class="colour-label">Sapwood</div><div class="colour-value">{sp.appearance.sapwood}</div></div>
    <div class="colour-item"><div class="colour-label">Texture</div><div class="colour-value">{sp.appearance.texture}</div></div>
    <div class="colour-item"><div class="colour-label">Lustre</div><div class="colour-value">{sp.appearance.luster}</div></div>
  </div>

  <div class="photo-grid">
    {images.length > 0 ? (
      images.slice(0, 3).map((img, i) => (
        <div class="photo-card">
          <img src={`/workshop/species-images/${img}`} alt={`${sp.name} — ${captions[i]}`}>
          <div class="photo-caption">{captions[i]}</div>
        </div>
      ))
    ) : (
      <div class="no-photos">No product images available for {sp.name}</div>
    )}
  </div>

  <div class="faq-section">
    <div class="section-title" style="margin-bottom: 6px;">Frequently Asked Questions</div>
    <div class="faq-grid">
      {sp.faqs.map(faq => (
        <div class="faq-item">
          <div class="faq-q">{faq.q}</div>
          <div class="faq-a">{faq.a}</div>
        </div>
      ))}
    </div>
  </div>

  <footer class="source-bar">
    {sp.name} Wood Species Reference Card &bull; Data compiled from industry sources &bull; For educational use
  </footer>
</div>
