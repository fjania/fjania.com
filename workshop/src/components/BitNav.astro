---
interface TypeCount {
  id: string;
  label: string;
  count: number;
}

interface Props {
  typeCounts: TypeCount[];
  brands: { value: string; label: string; icon: string }[];
}

const { typeCounts, brands } = Astro.props;

const tagColors: Record<string, string> = {
  pattern: 'var(--tag-pattern)',
  flush: 'var(--tag-flush)',
  roundover: 'var(--tag-roundover)',
  compression: 'var(--tag-compression)',
  spiral: 'var(--tag-spiral)',
  vgroove: 'var(--tag-vgroove)',
  chamfer: 'var(--tag-chamfer)',
  bowl: 'var(--tag-bowl)',
  ballnose: 'var(--tag-ballnose)',
  groove: 'var(--tag-groove)',
  spoilboard: 'var(--tag-spoilboard)',
  rabbeting: 'var(--tag-rabbeting)',
};
---

<nav class="side-nav">
  <div class="nav-title">Bit Types</div>
  {typeCounts.map(tc => (
    <a href={`#${tc.id}`}>
      <span class="nav-dot" style={`background:${tagColors[tc.id] || '#6b7280'}`}></span>
      {tc.label}
      <span class="nav-count">{tc.count}</span>
    </a>
  ))}
  <div class="nav-title" style="margin-top: 1.2rem;">Shank</div>
  <a href="#" class="nav-filter active" data-group="shank" data-value="1/4"><span class="nav-dot" style="background:#6b7280"></span> 1/4"</a>
  <a href="#" class="nav-filter active" data-group="shank" data-value="1/2"><span class="nav-dot" style="background:#6b7280"></span> 1/2"</a>
  <div class="nav-title" style="margin-top: 1.2rem;">Manufacturer</div>
  {brands.map(b => (
    <a href="#" class="nav-filter active" data-group="brand" data-value={b.value}>
      <img src={b.icon} class="nav-brand-icon"> {b.label}
    </a>
  ))}
  <div class="nav-title" style="margin-top: 1.2rem;">Status</div>
  <a href="#" class="nav-filter active" data-group="status" data-value="in-stock"><span class="nav-dot" style="background:#16a34a"></span> In Inventory</a>
  <a href="#" class="nav-filter active" data-group="status" data-value="shipped"><span class="nav-dot" style="background:#1d4ed8"></span> Shipped</a>
  <a href="#" class="nav-filter active" data-group="status" data-value="ordered"><span class="nav-dot" style="background:#059669"></span> Ordered</a>
  <a href="#" class="nav-filter active" data-group="status" data-value="backorder"><span class="nav-dot" style="background:#b45309"></span> Backorder</a>
</nav>
