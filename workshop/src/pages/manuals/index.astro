---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import '../../styles/manuals.css';

const manuals = await getCollection('manuals');
const sorted = manuals.sort((a, b) => a.data.name.localeCompare(b.data.name));

function categoryLabel(cat: string): string {
  return cat.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<Base title="Machine Manuals">
  <div class="manuals-listing">
    <h1>Machine Manuals</h1>
    <p class="subtitle">{sorted.length} {sorted.length === 1 ? 'manual' : 'manuals'} &mdash; downloadable PDFs and readable HTML references</p>

    <div class="manuals-grid">
      {sorted.map(manual => (
        <a href={`/workshop/manuals/${manual.id}/`} class="manual-card">
          <div class="category">{categoryLabel(manual.data.category)}</div>
          <h2>{manual.data.name}</h2>
          <p class="manufacturer">{manual.data.manufacturer}</p>
          <p class="meta">Model {manual.data.model} &middot; {manual.data.pages} pages</p>
        </a>
      ))}
    </div>
  </div>
</Base>
